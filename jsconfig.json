{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./frontend/src/*"],
      "@components/*": ["./frontend/src/components/*"],
      "@hooks/*": ["./frontend/src/hooks/*"],
      "@shared/*": ["./frontend/src/components/shared/*"],
      "@pages/*": ["./frontend/src/pages/*"],
      "@styles/*": ["./frontend/src/styles/*"],
      "@utils/*": ["./frontend/src/utils/*"],
      "@constants/*": ["./frontend/src/constants/*"],
      "@api/*": ["./frontend/src/api/*"],
      "#/*": ["./backend/*.js"],
      "#controllers/*": ["./backend/controllers/*.js"],
      "#models/*": ["./backend/models/*.js"],
      "#routes/*": ["./backend/routes/*.js"],
      "#middleware/*": ["./backend/middleware/*.js"],
      "#utils/*": ["./backend/utils/*.js"],
      "#constants/*": ["./backend/constants/*.js"],
      "#scripts/*": ["./backend/scripts/*.js"],
      "#data/*": ["./backend/data/*"]
    }
  },
  "exclude": ["node_modules", "frontend/dist", "backend/uploads"]
}
